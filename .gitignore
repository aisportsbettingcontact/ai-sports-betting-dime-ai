# Python bytecode
__pycache__/
*.pyc

# Ad-hoc workflow export; canonical workflows live in .github/workflows/
/github-workflows.zip

# Isolated agent workspaces (superpowers:using-git-worktrees)
.worktrees/
.claude/worktrees/
.superpowers/

# Claude skills symlinks (local tooling, not for deployment)
.claude/skills/*
# LiveLab skill is real project content, not a symlink
!.claude/skills/livelab/

# Audit notes, DB dumps, and run artifacts (non-sensitive but bulky)
audit-notes/

# Dev-runtime scrape/audit logs — never track
.scraper-logs/

# SEC-INC-001: secret-bearing debug/audit artifacts — local only, never track
database_audit.txt
debug_rg_today-hitters.html
debug_rg_today-pitchers.html
schema_alignment_findings.md


# Machine-specific Claude Code preferences (skill overrides etc.) — never share
.claude/settings.local.json

# Release-gate artifacts (generated)
vitest-results.json
env-gate-report.json
bundle-budget-report.json

# Security-audit gate artifacts (generated by osv-scanner)
osv-report.json

# Playwright CLI session artifacts (canonical matrix archive lives in docs/audits/)
.playwright-cli/

# Playwright Test (@playwright/test) run artifacts — e2e/, playwright.config.ts
test-results/
playwright-report/
blob-report/

