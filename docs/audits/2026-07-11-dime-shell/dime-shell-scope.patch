@@ -0,0 +1,80 @@
+/* derived: >=768 unified-shell arrangement; frozen child surfaces remain unchanged. */
+.dc-shell-stack {
+  flex: 1;
+  min-width: 0;
+  min-height: 0;
+  display: grid;
+  grid-template: minmax(0, 1fr) / minmax(0, 1fr);
+  overflow: hidden;
+  position: relative;
+}
+
+/* derived: pane layers share one cell to eliminate layout shift during URL swaps. */
+.dc-shell-chat-layer,
+.dc-shell-external-layer {
+  grid-area: 1 / 1;
+  width: 100%;
+  min-width: 0;
+  min-height: 0;
+}
+
+/* derived: embedded surfaces keep document-like scrolling inside the fixed app shell. */
+.dc-shell-external-layer {
+  overflow: hidden;
+}
+
+.theme-dark .dc-shell-external-layer {
+  background: #0b0b0f;
+}
+.theme-light .dc-shell-external-layer {
+  background: #ffffff;
+}
+
+.dc-shell-external-scroll {
+  width: 100%;
+  height: 100%;
+  min-width: 0;
+  min-height: 0;
+  overflow: auto;
+  overscroll-behavior: contain;
+  scrollbar-gutter: stable;
+}
+
+/* derived: one focusable semantic heading per embedded pane, visually absent. */
+.dc-shell-sr-only {
+  position: absolute;
+  width: 1px;
+  height: 1px;
+  padding: 0;
+  margin: -1px;
+  overflow: hidden;
+  clip: rect(0, 0, 0, 0);
+  white-space: nowrap;
+  border: 0;
+}
+
+.dc-shell-sr-only:focus {
+  outline: none;
+}
+
+/* derived: 768-1023 drawer shell reserves the shipped 56px top-bar lane. */
+@media (min-width: 768px) and (max-width: 1023px) {
+  .dc-shell-external-layer {
+    box-sizing: border-box;
+    padding-top: calc(56px + env(safe-area-inset-top));
+  }
+}
+
+/* derived: embedded full-page roots fill their pane without changing inner styling. */
+.dc-shell-external-scroll > .dmf-root,
+.dc-shell-external-scroll > .min-h-screen,
+.dc-shell-external-scroll > .bg-background {
+  min-height: 100%;
+}
+
+@media (prefers-reduced-motion: reduce) {
+  .dc-shell-chat-layer,
+  .dc-shell-external-layer {
+    transition: none !important;
+  }
+}
