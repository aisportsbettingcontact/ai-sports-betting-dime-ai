+      pane: "splits",
+    });
+    expect(parseDimeProductRoute("/betting-splits/mlb-07-11-2026")).toEqual({
+      pane: "splits",
+      sportSegment: "mlb-07-11-2026",
+      dateSegment: undefined,
+    });
+    expect(parseDimeProductRoute("/betting-splits/mlb/07-11-2026")).toEqual({
+      pane: "splits",
+      sportSegment: "mlb",
+      dateSegment: "07-11-2026",
+    });
