{
  "name": "ai-sports-betting",
  "version": "1.0.0",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "dev": "NODE_ENV=development tsx watch server/_core/index.ts",
    "build": "npm run build:client && node scripts/verify-preview-production.mjs dist/public && npm run build:server",
    "build:client": "vite build",
    "verify:preview-production": "vite build && node scripts/verify-preview-production.mjs dist/public",
    "build:server": "esbuild server/_core/index.ts --platform=node --packages=external --bundle --format=esm --outdir=dist && cp server/discord/splits_card.html dist/splits_card.html && cp server/nhl_model_engine.py dist/nhl_model_engine.py && cp server/MLBAIModel.py dist/MLBAIModel.py && cp server/StrikeoutModel.py dist/StrikeoutModel.py && cp server/ActionNetworkHRPropsAPI.py dist/ActionNetworkHRPropsAPI.py && cp server/ActionNetworkF5NrfiAPI.py dist/ActionNetworkF5NrfiAPI.py && cp server/wc2026/wc2026BracketScraper.mjs dist/wc2026BracketScraper.mjs && cp server/wc2026/v24_jul11_engine.mjs dist/v24_jul11_engine.mjs && cp server/wc2026/wc2026AuditEngine.mjs dist/wc2026AuditEngine.mjs && cp server/wc2026/groupStageGameIds.json dist/groupStageGameIds.json",
    "start": "NODE_ENV=production node dist/index.js",
    "check": "tsc --noEmit",
    "check:bundle": "node scripts/check-bundle-budget.mjs dist/public",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:gated:local": "(vitest run --reporter=default --reporter=json --outputFile=vitest-results.json || true) && node scripts/check-environment-failures.mjs --profile=local --input=vitest-results.json --report=env-gate-report.json",
    "test:gated:ci": "(vitest run --reporter=default --reporter=json --outputFile=vitest-results.json || true) && node scripts/check-environment-failures.mjs --profile=ci --input=vitest-results.json --actor=\"$GITHUB_ACTOR\" --report=env-gate-report.json",
    "smoke-test": "node -e \"import('./dist/index.js').then(() => { console.log('[SMOKE] Server initialized without crash'); process.exit(0); }).catch(e => { console.error('[SMOKE] CRASH:', e.message); process.exit(1); })\" & sleep 8 && kill %1 2>/dev/null; wait",
    "db:push": "drizzle-kit generate && drizzle-kit migrate",
    "postinstall": "if [ -f requirements.txt ] && command -v pip3 >/dev/null 2>&1; then pip3 install -r requirements.txt -q; else echo '[postinstall] skipping python deps: pip3 unavailable or requirements.txt missing (expected on Railway, which installs via apt in Dockerfile)'; fi"
  },
