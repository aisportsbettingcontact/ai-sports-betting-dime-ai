# =============================================================================
# .env.example — AI Sports Betting
# Copy to .env for local development. Never commit .env.
# All values are placeholders. Obtain real values from your own stores.
# =============================================================================

# -----------------------------------------------------------------------------
# CORE — Session & Database
# -----------------------------------------------------------------------------
# Session cookie signing secret (min 44 chars). Required at boot — server
# throws if absent. Generate with: openssl rand -base64 48
APP_SESSION_SECRET=
# MySQL/TiDB connection string
DATABASE_URL=
# Public-facing origin (e.g. https://aisportsbettingmodels.com)
PUBLIC_ORIGIN=

# -----------------------------------------------------------------------------
# MANUS PLATFORM — Replace all of these when migrating off Manus
# -----------------------------------------------------------------------------
VITE_APP_ID=
OAUTH_SERVER_URL=
VITE_OAUTH_PORTAL_URL=
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=
VITE_FRONTEND_FORGE_API_URL=
VITE_FRONTEND_FORGE_API_KEY=
OWNER_OPEN_ID=

# -----------------------------------------------------------------------------
# STRIPE — Payments
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=
VITE_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_MONTHLY=
STRIPE_PRICE_ANNUAL=

# -----------------------------------------------------------------------------
# DISCORD — Bot & OAuth
# -----------------------------------------------------------------------------
DISCORD_BOT_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_GUILD_ID=
DISCORD_PUBLIC_KEY=
DISCORD_ROLE_AI_MODEL_SUB=

# -----------------------------------------------------------------------------
# AI / LLM
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=

# -----------------------------------------------------------------------------
# SCRAPERS & DATA SOURCES
# -----------------------------------------------------------------------------
KENPOM_EMAIL=
KENPOM_PASSWORD=
ROTOGRINDERS_USERNAME=
ROTOGRINDERS_PASSWORD=
VSIN_EMAIL=
VSIN_PASSWORD=
METABET_API_KEY=

# -----------------------------------------------------------------------------
# OPS / INTEGRATIONS
# -----------------------------------------------------------------------------
GOOGLE_SERVICE_ACCOUNT_JSON=
GMAIL_APP_PASSWORD=
NBA_SHEET_ID=
HEARTBEAT_TOKEN=

# -----------------------------------------------------------------------------
# CONFIG (non-secret, but set for a complete local environment)
# -----------------------------------------------------------------------------
LOG_LEVEL=info
PLAYWRIGHT_CHROMIUM_PATH=
