# =============================================================================
# .env.example — AI Sports Betting
# Copy to .env for local development. Never commit .env.
# All values are placeholders. Obtain real values from your own stores.
# =============================================================================

# -----------------------------------------------------------------------------
# CORE — Session & Database
# -----------------------------------------------------------------------------
# Session cookie signing secret (min 44 chars). Required at boot — server
# throws if absent. Generate with: openssl rand -base64 48
APP_SESSION_SECRET=
# MySQL/TiDB connection string
DATABASE_URL=
# Public-facing origin (e.g. https://aisportsbettingmodels.com)
PUBLIC_ORIGIN=

# -----------------------------------------------------------------------------
# STRIPE — Payments
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=
VITE_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_MONTHLY=
STRIPE_PRICE_ANNUAL=

# -----------------------------------------------------------------------------
# DISCORD — Bot & OAuth
# -----------------------------------------------------------------------------
DISCORD_BOT_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_GUILD_ID=
DISCORD_PUBLIC_KEY=
DISCORD_ROLE_AI_MODEL_SUB=

# -----------------------------------------------------------------------------
# AI / LLM
# -----------------------------------------------------------------------------
# Anthropic credentials — direct key OR an Anthropic-compatible gateway.
# Direct Anthropic API key (sent as x-api-key). Leave EMPTY when routing
# through a gateway — Claude Code checks this variable first.
ANTHROPIC_API_KEY=
# --- Anthropic-compatible gateway routing (optional) — references/ai-gateway-setup.md ---
# When both ANTHROPIC_BASE_URL and ANTHROPIC_AUTH_TOKEN are set, ALL Claude
# traffic (Anthropic SDK calls in server/_core/claude.ts, dime-chat SSE, and the
# Claude Agent SDK in server/_core/dimeAgent.ts) routes through the gateway for
# usage monitoring + observability.
# Gateway host, e.g. https://your-gateway.example.com
ANTHROPIC_BASE_URL=
# Gateway API key (sent as Authorization: Bearer). Takes precedence over
# ANTHROPIC_API_KEY when set.
ANTHROPIC_AUTH_TOKEN=
# Optional model override for Agent SDK tasks (default claude-fable-5)
DIME_AGENT_MODEL=

# -----------------------------------------------------------------------------
# SCRAPERS & DATA SOURCES
# -----------------------------------------------------------------------------
KENPOM_EMAIL=
KENPOM_PASSWORD=
VSIN_EMAIL=
VSIN_PASSWORD=
METABET_API_KEY=

# -----------------------------------------------------------------------------
# OPS / INTEGRATIONS
# -----------------------------------------------------------------------------
GMAIL_APP_PASSWORD=
HEARTBEAT_TOKEN=

# -----------------------------------------------------------------------------
# DEPLOYMENT — Railway
# See references/railway-deploy.md
# -----------------------------------------------------------------------------
# Railway injects PORT automatically; the server binds it (default 3000 locally).
# Extra exact origins allowed for authenticated mutations (comma-separated) —
# e.g. the Railway domain, https://your-app.up.railway.app.
ADDITIONAL_ALLOWED_ORIGINS=
# Operator-controlled origin suffixes for per-deploy preview URLs (https-only).
# NEVER a bare shared suffix like .up.railway.app — scope to your team/project slug,
# e.g. -yourteam.up.railway.app
ALLOWED_ORIGIN_SUFFIXES=

# -----------------------------------------------------------------------------
# CONFIG (non-secret, but set for a complete local environment)
# -----------------------------------------------------------------------------
LOG_LEVEL=info
PLAYWRIGHT_CHROMIUM_PATH=
